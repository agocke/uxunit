<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <IsPackable>false</IsPackable>
    <IsTestProject>true</IsTestProject>
    <OutputType>Exe</OutputType>
    <Nullable>enable</Nullable>
    <IsAotCompatible>false</IsAotCompatible>
    <GenerateTestingPlatformEntryPoint>true</GenerateTestingPlatformEntryPoint>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp.Workspaces" />
    <PackageReference Include="Microsoft.CodeAnalysis.Analyzer.Testing" />
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp.SourceGenerators.Testing" />
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp" />
    <PackageReference Include="Microsoft.Testing.Platform.MSBuild" />
  </ItemGroup>

  <ItemGroup>
    <!-- Snapshot files are compared at runtime, not compiled. -->
    <Compile Remove="Snapshots/**/*.cs" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="../../src/NXTest.Core/NXTest.Core.csproj" />
    <ProjectReference Include="../../src/NXTest.Runtime/NXTest.Runtime.csproj" />
    <!-- Referenced twice: as a normal reference to use TestGenerator directly, and
         as an analyzer so NXTest discovers this project's own [Fact] tests. -->
    <ProjectReference
      Include="../../src/NXTest.Generators/NXTest.Generators.csproj"
      OutputItemType="Analyzer"
    />
  </ItemGroup>

  <!-- Run via the Microsoft.Testing.Platform auto-generated entry point. -->
  <Import Project="../../src/NXTest/build/NXTest.props" />
</Project>
